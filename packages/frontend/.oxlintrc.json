{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "jsPlugins": ["../../.claude/oxlint-plugins/design-system.js"],
  "overrides": [
    {
      "files": ["**/src/**/*.tsx"],
      "rules": {
        "design-system/no-raw-interactive-element": "error"
      }
    },
    {
      "files": ["**/src/components/ui/**/*.tsx"],
      "rules": {
        "design-system/no-raw-interactive-element": "off"
      }
    }
  ]
}
