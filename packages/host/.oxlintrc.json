{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "jsPlugins": ["../../.claude/oxlint-plugins/effect-patterns.js"],
  "overrides": [
    {
      "files": ["**/src/**/*.ts"],
      "rules": {
        "effect-patterns/no-date-clock": "error",
        "effect-patterns/no-inline-correlation-id": "error",
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "message": "Use Uint8Array (native) + Encoding from 'effect' for encode/decode. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:buffer"
              },
              {
                "message": "Use Command from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:child_process"
              },
              {
                "message": "Use FileSystem from '@effect/platform'. Skill: .agents/skills/effect-ts/references/guide-layers.md",
                "name": "node:fs"
              },
              {
                "message": "Use FileSystem from '@effect/platform'. Skill: .agents/skills/effect-ts/references/guide-layers.md",
                "name": "node:fs/promises"
              },
              {
                "message": "Use HttpServer from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:http"
              },
              {
                "message": "Use HttpClient from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:https"
              },
              {
                "message": "Use Path service from 'effect' + NodePath.layer from '@effect/platform-node'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:path"
              },
              {
                "message": "Use Console or the UserGateway driving port. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:readline"
              },
              {
                "message": "Use Stream from 'effect'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:stream"
              },
              {
                "message": "Use Url.fromString (effect/unstable/http) or Path.fromFileUrl for file URLs. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:url"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/adapters/**/*.ts", "**/src/checks/**/*.ts", "**/src/runtime/**/*.ts", "**/src/main.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["**/tests/**/*.ts"],
      "rules": {
        "effect-patterns/no-effect-gen-without-vitest": "error",
        "effect-patterns/no-runpromise-in-tests": "error"
      }
    },
    {
      "files": ["**/tests/helpers/**/*.ts"],
      "rules": {
        "effect-patterns/no-effect-gen-without-vitest": "off"
      }
    }
  ],
  "rules": {
    "import/no-nodejs-modules": "off"
  }
}
