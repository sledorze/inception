{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "suspicious": "error"
  },
  "ignorePatterns": ["node_modules", "dist", ".astro", "coverage", ".stryker-tmp", "vendor"],
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.config.ts",
        "**/*.config.mts",
        "**/packages/host/**"
      ],
      "rules": {
        "import/no-nodejs-modules": "off"
      }
    },
    {
      "files": ["**/packages/host/src/**/*.ts"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "message": "Use Clock.currentTimeMillis from 'effect' instead of Date.now() — enables TestClock in tests.",
            "selector": "CallExpression[callee.type='MemberExpression'][callee.object.name='Date'][callee.property.name='now']"
          },
          {
            "message": "Use Clock.currentTimeMillis from 'effect' instead of new Date() — enables TestClock in tests.",
            "selector": "NewExpression[callee.name='Date'][arguments.length=0]"
          }
        ]
      }
    },
    {
      "files": ["**/packages/host/tests/**/*.ts"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "message": "Use it.effect from '@effect/vitest' instead of Effect.runPromise in tests. Import { it } from '@effect/vitest'.",
            "selector": "CallExpression[callee.type='MemberExpression'][callee.object.name='Effect'][callee.property.name='runPromise']"
          }
        ]
      }
    }
  ],
  "plugins": ["unicorn", "typescript", "oxc", "vitest", "import", "react", "react-perf"],
  "rules": {
    "capitalized-comments": "off",
    "curly": "error",
    "eqeqeq": "error",
    "func-names": "off",
    "func-style": "off",
    "id-length": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/max-dependencies": "off",
    "import/no-named-export": "off",
    "import/no-namespace": "off",
    "import/no-nodejs-modules": "error",
    "import/no-unassigned-import": "off",
    "import/prefer-default-export": "off",
    "init-declarations": "off",
    "jest/require-hook": "off",
    "max-classes-per-file": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "max-params": "off",
    "max-statements": "off",
    "new-cap": "off",
    "no-await-in-loop": "off",
    "no-continue": "off",
    "no-duplicate-imports": "off",
    "no-inline-comments": "off",
    "no-magic-numbers": "off",
    "no-negated-condition": "off",
    "no-nested-ternary": "off",
    "no-shadow-restricted-names": "off",
    "no-ternary": "off",
    "no-unneeded-ternary": "error",
    "no-unused-vars": "error",
    "no-useless-constructor": "error",
    "no-useless-rename": "error",
    "no-warning-comments": "off",
    "prefer-destructuring": "off",
    "prefer-template": "error",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react/jsx-handler-names": "off",
    "react/jsx-max-depth": "off",
    "react/jsx-props-no-spreading": "off",
    "react/no-array-index-key": "off",
    "react/no-children-prop": "off",
    "react/react-in-jsx-scope": "off",
    "require-await": "off",
    "sort-imports": "off",
    "sort-keys": "error",
    "typescript/consistent-type-exports": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-useless-empty-export": "error",
    "typescript/parameter-properties": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/explicit-length-check": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-null": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-ternary": "off",
    "vitest/consistent-test-filename": "off",
    "vitest/expect-expect": "error",
    "vitest/no-disabled-tests": "error",
    "vitest/no-focused-tests": "error",
    "vitest/no-importing-vitest-globals": "off"
  },
  "settings": {
    "vitest": {
      "typecheck": false
    }
  }
}
