{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "suspicious": "error"
  },
  "ignorePatterns": ["node_modules", "dist", ".astro", "coverage", ".stryker-tmp", "vendor"],
  "jsPlugins": ["./.claude/oxlint-plugins/effect-patterns.js"],
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.config.ts",
        "**/*.config.mts",
        "**/packages/host/**"
      ],
      "rules": {
        "import/no-nodejs-modules": "off"
      }
    },
    {
      "files": ["**/packages/host/src/**/*.ts"],
      "rules": {
        "effect-patterns/no-date-clock": "error",
        "effect-patterns/no-inline-correlation-id": "error",
        "no-restricted-imports": [
          "warn",
          {
            "paths": [
              {
                "message": "Use Uint8Array (native) + Encoding from 'effect' for encode/decode. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:buffer"
              },
              {
                "message": "Use Command from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:child_process"
              },
              {
                "message": "Use FileSystem from '@effect/platform'. Skill: .agents/skills/effect-ts/references/guide-layers.md",
                "name": "node:fs"
              },
              {
                "message": "Use FileSystem from '@effect/platform'. Skill: .agents/skills/effect-ts/references/guide-layers.md",
                "name": "node:fs/promises"
              },
              {
                "message": "Use HttpServer from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:http"
              },
              {
                "message": "Use HttpClient from '@effect/platform'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:https"
              },
              {
                "message": "Use Path service from 'effect' + NodePath.layer from '@effect/platform-node'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:path"
              },
              {
                "message": "Use Console or the UserGateway driving port. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:readline"
              },
              {
                "message": "Use Stream from 'effect'. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:stream"
              },
              {
                "message": "Use Url.fromString (effect/unstable/http) or Path.fromFileUrl for file URLs. Skill: .agents/skills/effect-ts/references/features.md",
                "name": "node:url"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/packages/host/tests/**/*.ts"],
      "rules": {
        "effect-patterns/no-effect-gen-without-vitest": "error",
        "effect-patterns/no-runpromise-in-tests": "error"
      }
    }
  ],
  "plugins": ["unicorn", "typescript", "oxc", "vitest", "import", "react", "react-perf"],
  "rules": {
    "capitalized-comments": "off",
    "curly": "error",
    "eqeqeq": "error",
    "func-names": "off",
    "func-style": "off",
    "id-length": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/max-dependencies": "off",
    "import/no-named-export": "off",
    "import/no-namespace": "off",
    "import/no-nodejs-modules": "error",
    "import/no-unassigned-import": "off",
    "import/prefer-default-export": "off",
    "init-declarations": "off",
    "jest/require-hook": "off",
    "max-classes-per-file": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "max-params": "off",
    "max-statements": "off",
    "new-cap": "off",
    "no-await-in-loop": "off",
    "no-continue": "off",
    "no-duplicate-imports": "off",
    "no-inline-comments": "off",
    "no-magic-numbers": "off",
    "no-negated-condition": "off",
    "no-nested-ternary": "off",
    "no-shadow-restricted-names": "off",
    "no-ternary": "off",
    "no-underscore-dangle": "off",
    "no-unneeded-ternary": "error",
    "no-unused-vars": "error",
    "no-useless-constructor": "error",
    "no-useless-rename": "error",
    "no-warning-comments": "off",
    "prefer-destructuring": "off",
    "prefer-template": "error",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react/jsx-handler-names": "off",
    "react/jsx-max-depth": "off",
    "react/jsx-props-no-spreading": "off",
    "react/no-array-index-key": "off",
    "react/no-children-prop": "off",
    "react/react-in-jsx-scope": "off",
    "require-await": "off",
    "sort-imports": "off",
    "sort-keys": "error",
    "typescript/consistent-type-exports": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-useless-empty-export": "error",
    "typescript/parameter-properties": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/explicit-length-check": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-null": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-ternary": "off",
    "vitest/consistent-test-filename": "off",
    "vitest/expect-expect": "off",
    "vitest/max-expects": "off",
    "vitest/no-conditional-in-test": "off",
    "vitest/no-disabled-tests": "error",
    "vitest/no-focused-tests": "error",
    "vitest/no-hooks": "off",
    "vitest/no-importing-vitest-globals": "off",
    "vitest/no-standalone-expect": "off",
    "vitest/prefer-each": "off",
    "vitest/prefer-expect-assertions": "off",
    "vitest/prefer-importing-vitest-globals": "off",
    "vitest/prefer-lowercase-title": "off",
    "vitest/prefer-strict-boolean-matchers": "off",
    "vitest/prefer-strict-equal": "off",
    "vitest/prefer-to-be-truthy": "off",
    "vitest/prefer-to-have-length": "off",
    "vitest/require-hook": "off",
    "vitest/require-to-throw-message": "off",
    "vitest/require-top-level-describe": "off",
    "vitest/valid-title": "off",
    "vitest/warn-todo": "off"
  },
  "settings": {
    "vitest": {
      "typecheck": false
    }
  }
}
