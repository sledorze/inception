{
  "name": "my-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "cd packages/frontend && vite build",
    "check:test-conventions": "node --import tsx packages/host/src/checks/check-test-conventions.ts",
    "deps:check": "depcruise --validate .dependency-cruiser.cjs packages/host/src/ packages/frontend/src/",
    "dev": "tsx watch packages/host/src/main.ts",
    "dev:frontend": "cd packages/frontend && vite --host",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:ci": "prettier --check . --log-level warn",
    "lint": "oxlint . && node --import tsx packages/host/src/checks/check-test-conventions.ts",
    "lint:ci": "oxlint . --quiet && node --import tsx packages/host/src/checks/check-test-conventions.ts",
    "lint:fix": "oxlint --fix .",
    "prepare": "test -d .git && lefthook install || echo Skipping lefthook in CI",
    "start": "node --import tsx packages/host/src/main.ts",
    "stryker": "stryker run",
    "stryker:changed": "bash scripts/stryker-changed.sh",
    "stryker:frontend": "stryker run stryker.frontend.config.json",
    "syncpack:check": "syncpack lint",
    "syncpack:check:ci": "syncpack lint --log-levels error,warn",
    "syncpack:fix": "syncpack fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --reporter dot --silent",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p packages/host/tsconfig.json && tsc --noEmit -p packages/frontend/tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dependency-cruiser": "^17.3.9",
    "happy-dom": "^20.8.3",
    "lefthook": "^2.1.2",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "shadcn": "^4.0.2",
    "syncpack": "^14.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
