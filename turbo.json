{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#build:app": {
      "inputs": ["packages/app/**"],
      "outputs": ["packages/app/dist/**"]
    },
    "//#build:backoffice": {
      "inputs": ["packages/backoffice/**"],
      "outputs": ["packages/backoffice/dist/**"]
    },
    "//#deps:check": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        ".dependency-cruiser.cjs"
      ],
      "outputs": []
    },
    "//#format:check": {
      "inputs": ["**/*.{ts,tsx,json,md,yml,yaml,css,html}", ".prettierrc*", ".prettierignore"],
      "outputs": []
    },
    "//#format:check:ci": {
      "inputs": ["**/*.{ts,tsx,json,md,yml,yaml,css,html}", ".prettierrc*", ".prettierignore"],
      "outputs": []
    },
    "//#lint": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        ".oxlintrc.json"
      ],
      "outputs": []
    },
    "//#lint:ci": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        ".oxlintrc.json"
      ],
      "outputs": []
    },
    "//#syncpack:check": {
      "inputs": ["package.json", "packages/*/package.json", ".syncpackrc"],
      "outputs": []
    },
    "//#syncpack:check:ci": {
      "inputs": ["package.json", "packages/*/package.json", ".syncpackrc"],
      "outputs": []
    },
    "//#test:coverage": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        "vitest.config.ts"
      ],
      "outputs": ["coverage/**"]
    },
    "//#test:coverage:ci": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        "vitest.config.ts"
      ],
      "outputs": ["coverage/**"]
    },
    "//#typecheck": {
      "inputs": [
        "packages/host/src/**/*.ts",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/backoffice/src/**/*.{ts,tsx}",
        "packages/host/tsconfig.json",
        "packages/app/tsconfig.json",
        "packages/backoffice/tsconfig.json"
      ],
      "outputs": []
    }
  }
}
