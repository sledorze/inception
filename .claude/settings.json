{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/oxlint-autofix.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/oxlint-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/check-pain-closure.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/block-no-verify.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/block-oxlint-disable.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/session-context.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
